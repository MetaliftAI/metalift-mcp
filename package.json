{
  "name": "@metalift/mcp",
  "mcpName": "io.github.MetaLift-AI/metalift",
  "version": "1.0.11",
  "description": "Metalift MCP server for AI agents",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "bin": {
    "metalift-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "npm run build && node --test dist/client.test.js dist/scrape-args.test.js dist/scrape-format.test.js dist/web-search.test.js dist/startup-check.test.js dist/progress.test.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MetaLift-AI/metalift-mcp"
  },
  "publishConfig": {
    "access": "public"
  }
}
